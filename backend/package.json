{
  "name": "punjabi-wave-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "metadata:ingest": "tsx src/workers/ingestSong.ts",
    "db:migrate": "psql \"$DATABASE_URL\" -f sql/schema.sql",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.1",
    "dotenv": "^16.4.7",
    "fastify": "^4.29.0",
    "file-type": "^19.6.0",
    "fluent-ffmpeg": "^2.1.3",
    "music-metadata": "^10.6.4",
    "pg": "^8.13.1",
    "pino-pretty": "^13.0.0",
    "undici": "^6.21.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
